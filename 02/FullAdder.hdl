CHIP FullAdder {
    IN a, b, c;  
    OUT sum,     
        carry;   

    PARTS:
    Xor(a=a, b=b, out=s1);
    Xor(a=c, b=s1, out=sum);
    And(a=a , b=b , out=and1 );  
    And(a=a , b=c , out=and2 );  
    And(a=b , b=c , out=and3 );
    Or(a=and1 , b=and2 , out=or1 );  
    Or(a=or1 , b=and3 , out=carry );  
}